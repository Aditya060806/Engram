# ─── Backend env (copy to .env for local; the backend deploys on Render — set these in the Render dashboard for prod, or use render.yaml) ───

# LLM for Engram's own reasoning (Ask answers, reconciliation, Recap narrative).
# Groq is a reliable free option; Gemini keys must start with "AIza".
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
LLM_MODEL_FALLBACK=groq/llama-3.3-70b-versatile
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-2.5-flash
# GEMINI_API_KEY=your_AIza_gemini_key_here

# "development" lets local requests through via the X-User-Id header.
# Set to "production" on Render.
ENVIRONMENT=development

# Shared access key (must match frontend ENGRAM_ACCESS_KEY). Required in production.
ENGRAM_ACCESS_KEY=change-me-in-production

# Encrypts BYOK API keys at rest. Generate:
#   python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENGRAM_ENCRYPTION_KEY=your_encryption_key_here

# CORS origin for the frontend
FRONTEND_URL=http://localhost:3000

# Optional GitHub token for repo ingestion. Without it, GitHub's API is capped at
# 60 requests/hour and private repos are inaccessible; with it the cap is 5000/hour.
# Create a fine-grained or classic PAT (public_repo scope is enough for public repos).
# GITHUB_TOKEN=ghp_your_token_here

# Local Cognee init flags
MOCK_EMBEDDING=true
COGNEE_SKIP_CONNECTION_TEST=true

# ─── Cognee Cloud (optional) — routes remember/recall/improve/forget to a hosted tenant.
# Activates only when API key + service URL are both set. From your Cognee Cloud dashboard.
# COGNEE_API_KEY=your_cognee_cloud_api_key
# COGNEE_SERVICE_URL=https://<your-tenant>.aws.cognee.ai
# COGNEE_TENANT_ID=<your-tenant-uuid>

# ─── Production database (REQUIRED in production — PostgreSQL) ───
# On Render this is auto-wired from the engram-db instance in render.yaml.
# Elsewhere, set a Postgres connection string (Neon / Supabase / Vercel Postgres).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
