# ─── Frontend env (copy to .env.local for local dev; set in Vercel for prod) ───

# NextAuth v5 — REQUIRED. Generate: `openssl rand -base64 32`  (or node crypto)
AUTH_SECRET=

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
#   Callback URL: <site-url>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID → Web)
#   Authorized redirect URI: <site-url>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Backend location for the /api/proxy bridge.
# Local:      http://localhost:8000
# Production: REQUIRED on Vercel — set to your Render backend URL, e.g.
#   https://engram-backend.onrender.com
# (There is no combined deploy anymore, so the proxy cannot reach the backend without this.)
COGNEE_API_URL=http://localhost:8000

# Shared key forwarded to the backend as X-Engram-Key (must match backend ENGRAM_ACCESS_KEY)
ENGRAM_ACCESS_KEY=

# LOCAL DEV ONLY — enables a "Continue as guest" button so you can preview without OAuth.
# Leave BOTH unset in production so real OAuth is the only way in.
# ALLOW_GUEST_LOGIN=true
# NEXT_PUBLIC_ALLOW_GUEST_LOGIN=true
